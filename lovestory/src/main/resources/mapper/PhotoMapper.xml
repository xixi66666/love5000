<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ycxandwuqian.love.dao.PhotoDao">

    <resultMap id="PhotoRecordResultMap" type="com.ycxandwuqian.love.model.PhotoRecord">
        <id column="id" property="id"/>
        <result column="path" property="path"/>
        <result column="type" property="type"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.ycxandwuqian.love.model.PhotoRecord"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        insert into photo(path, type)
        values (#{path}, #{type})
    </insert>

    <select id="findAll" resultMap="PhotoRecordResultMap">
        select id, path, type, create_time
        from photo
        order by create_time desc, id desc
    </select>

    <select id="findById" resultMap="PhotoRecordResultMap">
        select id, path, type, create_time
        from photo
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from photo
        where id = #{id}
    </delete>
</mapper>
