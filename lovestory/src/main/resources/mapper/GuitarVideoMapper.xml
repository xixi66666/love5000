<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ycxandwuqian.love.dao.GuitarVideoDao">

    <resultMap id="GuitarVideoRecordResultMap" type="com.ycxandwuqian.love.model.GuitarVideoRecord">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="tag" property="tag"/>
        <result column="video_url" property="videoUrl"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="duration_seconds" property="durationSeconds"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.ycxandwuqian.love.model.GuitarVideoRecord"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        insert into guitar_video(
            title,
            description,
            tag,
            video_url,
            cover_url,
            duration_seconds,
            sort_order,
            status
        )
        values (
            #{title},
            #{description},
            #{tag},
            #{videoUrl},
            #{coverUrl},
            #{durationSeconds},
            #{sortOrder},
            #{status}
        )
    </insert>

    <select id="findVisible" resultMap="GuitarVideoRecordResultMap">
        select id,
               title,
               description,
               tag,
               video_url,
               cover_url,
               duration_seconds,
               sort_order,
               status,
               create_time,
               update_time
        from guitar_video
        where status = 1
        order by sort_order desc, create_time desc, id desc
    </select>

    <select id="findById" resultMap="GuitarVideoRecordResultMap">
        select id,
               title,
               description,
               tag,
               video_url,
               cover_url,
               duration_seconds,
               sort_order,
               status,
               create_time,
               update_time
        from guitar_video
        where id = #{id}
    </select>

    <update id="updateCoverUrl">
        update guitar_video
        set cover_url = #{coverUrl}
        where id = #{id}
    </update>

    <update id="hideById">
        update guitar_video
        set status = 0
        where id = #{id}
    </update>
</mapper>
